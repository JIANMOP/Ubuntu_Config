#!/bin/bash
clear

# 颜色定义
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # 无颜色

echo "=============================="
echo -e "  ${GREEN}SSH Port Forward${NC}"
echo "=============================="
echo -e "${YELLOW}Loading hosts from ~/.ssh/config...${NC}"

# 安全解析 SSH 配置（忽略 * 通配符，忽略注释）
hosts=()
while IFS= read -r line; do
    # 匹配以 Host 开头，非注释，非 * 的主机名
    if [[ "$line" =~ ^Host[[:space:]]+[^*\#] ]]; then
        host=$(echo "$line" | awk '{print $2}')
        hosts+=("$host")
    fi
done < ~/.ssh/config

# 排序
IFS=$'\n' hosts=($(sort <<<"${hosts[*]}"))
unset IFS

echo ""
echo "0) Custom manual host (user@ip -p 22)"
for i in "${!hosts[@]}"; do
    echo "$((i + 1))) ${hosts[$i]}"
done

# 选择主机
read -p $'\nEnter option number: ' sel
target_host=""

if [[ "$sel" == "0" ]]; then
    read -p "Enter custom ssh host (user@ip -p 22): " target_host
else
    idx=$((sel - 1))
    if [[ $idx -lt 0 || -z "${hosts[$idx]}" ]]; then
        echo -e "${RED}Error: Invalid selection.${NC}"
        exit 1
    fi
    target_host="${hosts[$idx]}"
fi

# 端口输入 + 数字校验 + 端口范围校验
read -p "Remote service port: " remote_port
read -p "Local access port: " local_port

if ! [[ "$remote_port" =~ ^[0-9]+$ && "$local_port" =~ ^[0-9]+$ ]]; then
    echo -e "${RED}Error: Port must be numeric.${NC}"
    exit 1
fi

if (( remote_port < 1 || remote_port > 65535 || local_port < 1 || local_port > 65535 )); then
    echo -e "${RED}Error: Port must be between 1 and 65535.${NC}"
    exit 1
fi

# 检查本地端口是否被占用
if lsof -Pi :"$local_port" -sTCP:LISTEN -t >/dev/null 2>&1; then
    echo -e "${RED}Error: Local port $local_port is already in use!${NC}"
    exit 1
fi

# 选择监听地址
echo -e "\n--- Listen Address ---"
echo "1) 127.0.0.1 (Local only)"
echo "2) 0.0.0.0 (LAN accessible)"
read -p "Select listen address [1/2]: " listen_opt

if [[ "$listen_opt" == "2" ]]; then
    listen_ip="0.0.0.0"
else
    listen_ip="127.0.0.1"
fi

# 启动端口转发（增加错误检测）
echo -e "\n${YELLOW}Starting port forwarding...${NC}"
ssh -Nf -L "$listen_ip:$local_port:127.0.0.1:$remote_port" "$target_host"

# 检查 SSH 命令是否执行成功
if [[ $? -ne 0 ]]; then
    echo -e "${RED}Failed to start SSH port forward!${NC}"
    exit 1
fi

# 成功提示
echo -e "\n${GREEN}Forward started successfully!${NC}"
echo "Listen IP: $listen_ip"
echo "Local access: http://localhost:$local_port"
if [[ "$listen_ip" == "0.0.0.0" ]]; then
    echo "LAN access: http://[your-local-ip]:$local_port"
fi
echo -e "${YELLOW}Stop this forward: pkill -f \"ssh.*:$local_port\"${NC}"
